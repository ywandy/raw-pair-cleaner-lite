{
  "name": "raw-pair-cleaner-lite",
  "private": true,
  "version": "0.1.0-beta.4",
  "type": "module",
  "scripts": {
    "dev": "pnpm tauri dev",
    "dev:web": "vite",
    "build:web": "pnpm typecheck && vite build",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "stage:sidecar": "node scripts/stage-sidecar.mjs",
    "build": "pnpm build:sidecar && pnpm stage:sidecar && pnpm tauri build --bundles app",
    "build:updater": "pnpm build:sidecar && pnpm stage:sidecar && pnpm tauri build --bundles app --config src-tauri/tauri.updater.conf.json",
    "collect:release": "node scripts/collect-release-artifacts.mjs",
    "latest:updater": "node scripts/create-latest-json.mjs",
    "version:check": "node scripts/release-gate.mjs --version-only",
    "release:check": "node scripts/release-gate.mjs",
    "preview": "vite preview",
    "test": "vitest run src scripts && pnpm --filter ./sidecar test",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "~2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-shell": "~2.3.5",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^24.12.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.7"
  }
}
